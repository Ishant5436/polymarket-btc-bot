# =============================================================================
# Polymarket BTC Bot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# --- Polygon Wallet ---
# Private key for signing EIP-712 payloads (no 0x prefix)
POLYGON_PRIVATE_KEY=

# Wallet address that holds USDC.e funds on Polygon
FUNDER_ADDRESS=

# Signature type: 0 = EOA/MetaMask, 1 = Polymarket proxy wallet, 2 = Polymarket Gnosis Safe.
# If preflight shows an unexpected balance/allowance, verify this setting first.
SIGNATURE_TYPE=0

# --- Polymarket L2 HMAC Credentials ---
# Generated by registering your wallet with Polymarket
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
# Optional: force the bot to target a specific live event page.
# Example: bitcoin-up-or-down-april-6-2026-5pm-et
# POLYMARKET_EVENT_SLUG=

# --- Trading Parameters (optional overrides) ---
# DRY_RUN=true
# VALIDATION_ONLY_MODE=false
# LIVE_TRADING_ENABLED=false
# ALLOW_NON_5M_LIVE_MARKETS=false
# Validation-only mode can also be invoked without editing .env:
# venv/bin/python -m src.execution.engine --validation-only
# MIN_EDGE=0.02
# MIN_SIDE_PROBABILITY=0.52
# MAX_ENTRY_PRICE=0.90
# STRATEGY_STYLE=momentum
# PROBABILITY_VOL_WINDOW_SECONDS=300
# PROBABILITY_MIN_SIGMA=0.0015
# ORDER_BOOK_IMBALANCE_LEVELS=5
# MIN_ORDER_BOOK_IMBALANCE=0.35
# MAX_ASK_WALL_RATIO=2.5
# ORDER_SIZE=1.0
# ORDER_NOTIONAL=1.0
# GTD_TTL_SECONDS=10
# MAX_OPEN_POSITIONS=3
# DUPLICATE_SIGNAL_WINDOW_SECONDS=15
# REQUIRE_LIVE_TEST_BEFORE_LIVE_ORDERS=true
# LIVE_TEST_WINDOW_SECONDS=600
# LIVE_TEST_MIN_COMPLETED_MARKETS=2
# LIVE_TEST_MIN_WIN_RATE=0.50
# LIVE_TEST_MIN_PROFIT=0.01
# LIVE_TEST_MAX_CUMULATIVE_LOSS=0.00
# ALLOW_UPSIZE_TO_MIN_ORDER_SIZE=false
# BANKROLL_FRACTION_PER_ORDER=1.0
# MAX_ORDER_NOTIONAL=0.0
# RESERVE_COLLATERAL_AMOUNT=0.0
# ENABLE_DYNAMIC_EXITS=true
# STOP_LOSS_FACTOR=0.5
# TAKE_PROFIT_MULTIPLE=3.0
# TAKE_PROFIT_FRACTION=0.5
# TIME_DECAY_EXIT_SECONDS=1800
# TIME_DECAY_DISTANCE_PCT=0.005
# PNL_FLOOR=-0.20

# --- Risk Parameters (optional overrides) ---
# VOLATILITY_SIGMA_THRESHOLD=3.0
# KILL_SWITCH_COOLDOWN_SECONDS=60
# PRIVATE_CHECK_CACHE_TTL_SECONDS=5.0

# --- Live State Parameters (optional overrides) ---
# ROLLING_STATE_MAXLEN=50000
# MIN_WARMUP_TRADES=1000
# MIN_HISTORY_SECONDS=3600

# --- Artifacts / Audit Trail (optional overrides) ---
# ARTIFACTS_DIR=data/artifacts
